{
  "expo": {
    "name": "parensure",
    "slug": "parensure",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icons/PHeart-xparent.png",
    "scheme": "parensure",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.parensure.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification", "fetch"],
        "NSLocationWhenInUseUsageDescription": "Parensure uses your location to help match you with nearby caregivers.",
        "NSCameraUsageDescription": "Parensure uses your camera to capture profile photos and documents.",
        "NSPhotoLibraryUsageDescription": "Parensure accesses your photo library to upload profile photos and documents.",
        "NSMicrophoneUsageDescription": "Parensure uses the microphone for video features within the app."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/PHeart-xparent.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "package": "com.parensure",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#E84545",
          "sounds": []
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Parensure to use Face ID for secure sign in."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icons/PHeart-xparent.png",
          "imageWidth": 200,
          "imageHeight": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbc2a400-5a61-432d-8cf9-4153bd66d329"
      }
    }
  }
}
